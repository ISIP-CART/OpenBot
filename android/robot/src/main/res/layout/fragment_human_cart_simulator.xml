<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".cartfollow.HumanCartSimulatorFragment">

    <org.openbot.customview.OverlayView
        android:id="@+id/tracking_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/command_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="120dp"
        android:background="#80000000"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:text="@string/cart_sim_idle"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/debug_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="#80000000"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/debug_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            tools:text="fps=0.0\nstate=IDLE\naction=-\npersons=0" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_debug_details"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:text="调试详情"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_target_event"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:enabled="false"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:text="目标离开画面"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/countdown_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="#CC000000"
        android:paddingHorizontal="32dp"
        android:paddingVertical="16dp"
        android:textColor="#FFFFFF"
        android:textSize="56sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/confirm_panel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/confirm_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="#CC000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/real_control_panel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/snapshot_view"
            android:layout_width="96dp"
            android:layout_height="128dp"
            android:background="#33000000"
            android:contentDescription="@string/cart_simulator"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="是否跟随此人？"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_confirm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="确认" />

                <Button
                    android:id="@+id/btn_retake"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="重拍" />

                <Button
                    android:id="@+id/btn_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="取消" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/real_control_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#E6000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/bottom_panel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/real_connection_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BLE 未连接"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/real_mode_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/real_mode_manual"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="手动" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/real_mode_auto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="自动实验" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <LinearLayout
            android:id="@+id/manual_drive_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:splitMotionEvents="true"
            android:orientation="horizontal">

            <Button
                android:id="@+id/drive_left"
                android:layout_width="56dp"
                android:layout_height="48dp"
                android:text="↶"
                android:textSize="22sp" />

            <Button
                android:id="@+id/drive_forward"
                android:layout_width="56dp"
                android:layout_height="48dp"
                android:text="↑"
                android:textSize="22sp" />

            <Button
                android:id="@+id/drive_backward"
                android:layout_width="56dp"
                android:layout_height="48dp"
                android:text="↓"
                android:textSize="22sp" />

            <Button
                android:id="@+id/drive_right"
                android:layout_width="56dp"
                android:layout_height="48dp"
                android:text="↷"
                android:textSize="22sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/connect_ble"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="连接 BLE" />

            <Button
                android:id="@+id/unlock_auto"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="长按解锁自动"
                android:visibility="gone" />

            <Button
                android:id="@+id/emergency_stop"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#D32F2F"
                android:text="急停"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <TextView
            android:id="@+id/real_safety_notice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="近场传感器未接入，仅限空旷实验"
            android:textColor="#FFFF8A80"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:paddingVertical="12dp"
                android:paddingStart="8dp"
                android:text="@string/model"
                android:textColor="@android:color/white" />

            <Spinner
                android:id="@+id/model_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.6"
                android:prompt="@string/model" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:paddingStart="8dp"
                android:text="@string/confidence"
                android:textColor="@android:color/white" />

            <ImageView
                android:id="@+id/minus_confidence"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.3"
                android:contentDescription="@string/minus"
                android:src="@drawable/ic_baseline_remove" />

            <TextView
                android:id="@+id/confidence_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:gravity="center"
                android:padding="4dp"
                android:text="50%"
                android:textColor="@android:color/white" />

            <ImageView
                android:id="@+id/plus_confidence"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.3"
                android:contentDescription="@string/plus"
                android:src="@drawable/ic_baseline_add" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.2" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/diagnostic_switch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:checked="false"
                android:text="记录日志"
                android:textColor="@android:color/white" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/start_switch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:text="@string/cart_sim_start"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
